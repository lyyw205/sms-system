# Demo Mode — LLM mock/real, JWT/password auto-gen, CORS relaxation
DEMO_MODE=true

# Swagger UI — 미설정 시 DEMO_MODE 따라감
# ENABLE_SWAGGER=true

# Database
DATABASE_URL=postgresql://smsuser:smspass@localhost:5432/smsdb

# Redis
REDIS_URL=redis://localhost:6379

# ChromaDB
CHROMADB_URL=http://localhost:8001

# Aligo SMS API (실제 발송 여부는 DB tenant.aligo_testmode로 제어)
# 알리고 계정: https://smartsms.aligo.in
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=                  # 발신번호 (사전 등록 필요, 예: 01012345678)

# SMS Webhook (optional)
SMS_WEBHOOK_URL=

# Claude API (Only needed when DEMO_MODE=false)
CLAUDE_API_KEY=

# Google Sheets (Only needed when DEMO_MODE=false)
GOOGLE_SHEETS_CREDENTIALS=

# Naver Reservation (Only needed when DEMO_MODE=false)
NAVER_RESERVATION_EMAIL=
NAVER_RESERVATION_PASSWORD=

# JWT Authentication (데모 모드에서는 자동 생성됨, 고정하려면 설정)
# 생성 방법: openssl rand -hex 32
# JWT_SECRET_KEY=your-secret-key-here

# Default Passwords (데모 모드에서는 자동 생성됨)
# ADMIN_DEFAULT_PASSWORD=your-admin-password
# STAFF_DEFAULT_PASSWORD=your-staff-password
